{
  "schema": "YuEngine.Project/0.1",
  "project_id": "touhou_new_world_sample",
  "display_name": "Touhou New World Sample",
  "role": "sample_oracle",
  "engine_profile": "ankake_kengeki_derived",
  "language": {
    "default": "sc",
    "supported": ["jp", "en", "sc", "tc"]
  },
  "mounts": [
    {
      "id": "rpack_manifest",
      "type": "pack_manifest",
      "path": "../../../Project/output/assets/rpack_manifest.json"
    },
    {
      "id": "loose_resource",
      "type": "loose",
      "path": "../../../resource"
    },
    {
      "id": "extracted_assets",
      "type": "loose",
      "path": "../../../Project/output/assets/merged"
    }
  ],
  "script_roots": [
    {
      "type": "sqasm",
      "path": "../../../Project/output/scripts"
    }
  ],
  "startup": {
    "preload_scripts": ["preload.b64"],
    "entry_module": "script/menu/titlemenu.b64",
    "entry_function": "setupProc"
  },
  "data": {
    "info_db": "../../../resource/data/info.db3",
    "dialogs": "../../../resource/dialogs.json",
    "config": "../../../resource/ak3.json",
    "texts": null
  },
  "runtime": {
    "renderer": "d3d9_compatible",
    "script_vm": "squirrel_2_2_4",
    "audio": "ogg_se_pack",
    "save_policy": "local_profile"
  },
  "resources": {
    "required": [
      {
        "kind": "stem",
        "path": "menu/title/title_back",
        "purpose": "title background language variants"
      },
      {
        "kind": "stem",
        "path": "menu/title/logo",
        "purpose": "title logo language variants"
      },
      {
        "kind": "path",
        "path": "hud/titlemenu/title_demo.dds",
        "purpose": "title demo badge"
      },
      {
        "kind": "path",
        "path": "map/doujou/doujou.sge",
        "purpose": "first mission stage"
      },
      {
        "kind": "path",
        "path": "map/doujou/doujou.rcm",
        "purpose": "first mission rail camera"
      }
    ]
  },
  "oracle": {
    "title_entry_script": "script/menu/titlemenu.b64.sqasm",
    "first_mission_candidate": "mission/sc01/main/ms010_0.b64.sqasm"
  }
}
