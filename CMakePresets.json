{
  "version": 8,
  "configurePresets": [
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-debug-vs",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-release-vs",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-fast-gate",
      "displayName": "Windows Fast Gate",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-fast-gate-vs",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    },
    {
      "name": "windows-fast-gate",
      "configurePreset": "windows-fast-gate",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "windows-fast-gate",
      "configurePreset": "windows-fast-gate",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "exclude": {
          "label": "HardwareSmoke"
        }
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "windows-hardware-smoke",
      "configurePreset": "windows-fast-gate",
      "configuration": "Debug",
      "filter": {
        "include": {
          "label": "HardwareSmoke"
        }
      },
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "ignore"
      }
    }
  ]
}
